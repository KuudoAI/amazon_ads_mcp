# Keep Docker build context minimal and deterministic.
# The Dockerfile only copies:
# - pyproject.toml, uv.lock, README.md, build_package.py
# - src/
# - scripts/docker-entrypoint.py
# - dist/openapi/resources/
# - dist/openapi/overlays/

# Ignore everything by default.
**

# Keep Docker metadata.
!.dockerignore
!Dockerfile
!Dockerfile.metering

# Local private metering artifacts are bind-mounted by Dockerfile.metering.
# They remain ignored by Git and are never copied into an image layer.
!.build/
!.build/metering/
!.build/metering/**

# Keep dependency metadata and package source.
!pyproject.toml
!uv.lock
!README.md
!build_package.py
!src/
!src/**
!scripts/
!scripts/docker-entrypoint.py

# Keep runtime OpenAPI artifacts used by the image.
# Both resources/ and overlays/ live under dist/openapi/ — the canonical
# deployment home for OpenAPI assets. Parents (!dist/, !dist/openapi/)
# must be unignored before leaf-level whitelists take effect under
# Docker's deny-by-default semantics.
!dist/
!dist/openapi/
!dist/openapi/resources/
!dist/openapi/resources/**
!dist/openapi/overlays/
!dist/openapi/overlays/**
